# MLCouncil environment variables template.
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# --- Alpaca (paper trading) ---
ALPACA_API_KEY=replace-me
ALPACA_SECRET_KEY=replace-me
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_KEY=replace-me
ALPACA_PAPER_SECRET=replace-me
TRADING_MODE=paper

# --- Polygon (optional, historical data) ---
POLYGON_API_KEY=replace-me

# --- Email alerts ---
ALERT_EMAIL=your-email@gmail.com
SMTP_PASSWORD=replace-me

# --- Data stores ---
ARCTICDB_URI=lmdb://data/arctic/
MLFLOW_TRACKING_URI=http://localhost:5000
DATABASE_URL=postgresql://mlcouncil:password@localhost:5432/mlcouncil

# --- Runtime ---
MLCOUNCIL_ENV_PROFILE=local
MLCOUNCIL_AUTO_EXECUTE=false
MLCOUNCIL_MAX_DAILY_ORDERS=20
MLCOUNCIL_MAX_TURNOVER=0.30
MLCOUNCIL_MAX_POSITION_SIZE=0.10
MLCOUNCIL_AUTOMATION_PAUSED=false

# --- Ports (Docker) ---
ADMIN_API_PORT=8000
DASHBOARD_PORT=8501
DAGSTER_PORT=3000
MLFLOW_PORT=5000
