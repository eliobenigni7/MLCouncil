# Alpaca Paper Trading
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_CRYPTO_URL=https://paper-api.alpaca.markets

# Trading limits
MLCOUNCIL_MAX_DAILY_ORDERS=20
MLCOUNCIL_MAX_TURNOVER=0.30
MLCOUNCIL_MAX_POSITION_SIZE=0.10
MLCOUNCIL_AUTO_EXECUTE=false
MLCOUNCIL_ENV_PROFILE=paper

# Crypto
MLCOUNCIL_CRYPTO_ENABLED=true
MLCOUNCIL_MAX_CRYPTO_POSITION_SIZE=0.20
MLCOUNCIL_MAX_CRYPTO_TURNOVER=0.40
MLCOUNCIL_INTRADAY_UNIVERSE=BTCUSD,ETHUSD,AAPL,MSFT,NVDA,AMZN,META,GOOGL,TSLA
